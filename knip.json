{
	"$schema": "https://unpkg.com/knip@latest/schema.json",
	"ignore": [
		"**/__tests__/**",
		"apps/vscode-e2e/**",
		"src/extension/api.ts",
		"src/activate/**",
		"src/workers/countTokens.ts",
		"src/extension.ts",
		"scripts/**",
		"apps/cli/scripts/**"
	],
	"workspaces": {
		"src": {
			"entry": ["extension.ts"],
			"project": ["**/*.ts"]
		},
		"webview-ui": {
			"entry": ["src/index.tsx"],
			"project": ["src/**/*.{ts,tsx}", "../src/shared/*.ts"]
		},
		"apps/docs": {
			"entry": ["src/clientModules/**/*.{ts,tsx}", "src/components/**/*.{ts,tsx}", "src/theme/**/*.{ts,tsx}"],
			"project": ["src/**/*.{ts,tsx}"]
		},
		"packages/{build,evals,ipc,types}": {
			"project": ["src/**/*.ts"]
		}
	}
}
